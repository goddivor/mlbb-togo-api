# Base de données : MongoDB (replica set requis par Prisma, même mono-nœud).
# Démarrage local d'une instance dédiée en replica set :
#   mongod --dbpath ~/.mlbb-mongo/data --replSet rs0 --bind_ip 127.0.0.1 --port 27017 \
#          --unixSocketPrefix ~/.mlbb-mongo --fork --logpath ~/.mlbb-mongo/mongod.log
#   mongosh --port 27017 --eval 'rs.initiate({_id:"rs0",members:[{_id:0,host:"127.0.0.1:27017"}]})'
# Puis, après `prisma db push`, créer les index uniques partiels :
#   mongosh "$DATABASE_URL" prisma/mongo-indexes.js
DATABASE_URL="mongodb://127.0.0.1:27017/mlbb_togo?replicaSet=rs0"

# Authentification JWT
JWT_SECRET="change-me-en-production-mlbb-togo-secret"
JWT_EXPIRES_IN="7d"

# Connexion Google (OAuth) — laisser vide si non utilisé
GOOGLE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"

# Serveur
PORT=3006

# CORS : origine du frontend Next.js
FRONTEND_URL="http://localhost:3005"
