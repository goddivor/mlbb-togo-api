
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  username       String    @unique
  email          String    @unique
  password       String
  avatar         String?
  rank           String    @default("warrior")
  role           String    @default("fighter")
  favoriteHeroes String    @default("[]")
  wins           Int       @default(0)
  losses         Int       @default(0)
  mvpCount       Int       @default(0)
  streak         Int       @default(0)
  country        String    @default("Togo")
  city           String?
  bio            String?
  badges         String    @default("[]")
  joinedAt       DateTime  @default(now())
  lastActive     DateTime  @default(now())
  isOnline       Boolean   @default(false)
  isBanned       Boolean   @default(false)
  roleUser       String    @default("user")

  provider       String    @default("local")

  googleId       String?
  googleEmail    String?
  googleName     String?
  googleAvatar   String?

  mlbbRoleId     Int?
  mlbbZoneId     Int?
  mlbbToken      String?
  gameNickname   String?
  gameAvatar     String?
  gameLevel      Int?
  gameRankLevel  Int?
  gameCountry    String?
  gameStats      String    @default("{}")
  gameFrequentHeroes String @default("[]")
  gameRoles      String    @default("[]")
  gameSeasons    String    @default("[]")
  gameSyncedAt   DateTime?

  profileSource  String    @default("game")
  teamId         String?   @db.ObjectId
  team           Team?     @relation("TeamMembers", fields: [teamId], references: [id])
  posts          Post[]
  comments       Comment[]
  esportMemberships EsportTeamMember[] @relation("EsportMemberships")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Team {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  tag          String
  logo         String?
  description  String?
  captainId    String?
  members      User[]   @relation("TeamMembers")
  maxMembers   Int      @default(7)
  wins         Int      @default(0)
  losses       Int      @default(0)
  rank         Int      @default(0)
  foundedAt    DateTime @default(now())
  region       String   @default("Togo")
  achievements String   @default("[]")
  isRecruiting Boolean  @default(false)
  lookingFor   String   @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Post {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  authorId   String    @db.ObjectId
  author     User?     @relation(fields: [authorId], references: [id])
  authorName String
  authorRank String?
  category   String
  title      String
  content    String
  likes      Int       @default(0)
  views      Int       @default(0)
  isPinned   Boolean   @default(false)
  comments   Comment[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Comment {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  postId     String   @db.ObjectId
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId   String   @db.ObjectId
  author     User?    @relation(fields: [authorId], references: [id])
  authorName String
  content    String
  createdAt  DateTime @default(now())
}

model Tournament {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  description     String?
  organizer       String?
  status          String   @default("upcoming")
  startDate       String?
  endDate         String?
  prizePool       String?
  maxTeams        Int      @default(16)
  registeredTeams String   @default("[]")
  format          String?
  rules           String?
  banner          String?
  brackets        String   @default("[]")
  streamUrl       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Event {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  title        String
  type         String
  description  String?
  date         String?
  time         String?
  duration     String?
  participants String   @default("[]")
  organizer    String?
  isPublic     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model Match {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  team1      String
  team2      String
  tournament String?
  date       String?
  status     String   @default("upcoming")
  mvp        String?
  duration   String?
  format     String?
  games      String   @default("[]")
  createdAt  DateTime @default(now())
}

model Hero {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique
  role        String
  image       String?
  description String?
  createdAt   DateTime @default(now())
}

model AdminLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  action    String
  admin     String
  target    String?
  details   String?
  timestamp DateTime @default(now())
}

model FormTemplate {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  fields      String         @default("[]")
  status      String         @default("active")
  responses   FormResponse[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model FormResponse {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  formId      String       @db.ObjectId
  form        FormTemplate @relation(fields: [formId], references: [id], onDelete: Cascade)
  data        String       @default("{}")
  submittedAt DateTime     @default(now())
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @db.ObjectId
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

model Esport {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  logo        String?
  color       String?
  description String?
  teams       EsportTeam[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model EsportTeam {
  id           String             @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  image        String?
  description  String?
  type         String             @default("community")
  isRecruiting Boolean            @default(false)
  esportId     String?            @db.ObjectId
  esport       Esport?            @relation(fields: [esportId], references: [id], onDelete: Cascade)
  members      EsportTeamMember[]
  sort         Int                @default(0)
  foundedAt    DateTime           @default(now())
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model EsportTeamMember {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  teamId       String     @db.ObjectId
  team         EsportTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId       String     @db.ObjectId
  user         User       @relation("EsportMemberships", fields: [userId], references: [id], onDelete: Cascade)
  role         String?
  isCaptain    Boolean    @default(false)
  isSubstitute Boolean    @default(false)
  sort         Int        @default(0)
  joinedAt     DateTime   @default(now())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([teamId, userId])
}

model Sponsor {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String?
  logo      String
  url       String?
  sort      Int      @default(0)
  createdAt DateTime @default(now())
}

model EsportSeason {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  isActive    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model EsportMatch {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  seasonId     String?   @db.ObjectId
  type         String    @default("friendly")
  teamAId      String    @db.ObjectId
  teamBId      String    @db.ObjectId
  scheduledAt  DateTime?
  status       String    @default("scheduled")
  scoreA       Int       @default(0)
  scoreB       Int       @default(0)
  winnerTeamId String?   @db.ObjectId
  notes        String?
  createdById  String?   @db.ObjectId
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model EsportJoinRequest {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  teamId    String   @db.ObjectId
  userId    String   @db.ObjectId
  role      String?
  message   String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamRequest {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  requesterId   String   @db.ObjectId
  proposedName  String
  message       String?
  status        String   @default("pending")
  createdTeamId String?  @db.ObjectId
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model MessageThread {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  subject        String?
  requestId      String?  @db.ObjectId
  participantIds String[]
  lastMessageAt  DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Message {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  threadId  String   @db.ObjectId
  senderId  String   @db.ObjectId
  body      String
  createdAt DateTime @default(now())
}

model Mtl {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  season      String?
  description String?
  startDate   String?
  endDate     String?
  images      MtlImage[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model MtlImage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  image     String
  caption   String?
  sort      Int      @default(0)
  mtlId     String   @db.ObjectId
  mtl       Mtl      @relation(fields: [mtlId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String
  subject   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
